          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "spec": {
                        "query": "data = from(bucket: \"my-bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"rating\")\n  |> filter(fn: (r) => r[\"player\"] == \"annacramling\")\n  |> filter(fn: (r) => r[\"time_class\"] == \"blitz\")\n  |> filter(fn: (r) => r[\"_field\"] == \"elo\")\n\nhigh = data |> aggregateWindow(every: 1mo, fn: max, createEmpty: false) |> set(key: \"_field\", value: \"high\")\nlow = data |> aggregateWindow(every: 1mo, fn: min, createEmpty: false) |> set(key: \"_field\", value: \"low\")\nclose = data |> aggregateWindow(every: 1mo, fn: last, createEmpty: false) |> set(key: \"_field\", value: \"close\")\nvolume = data |> aggregateWindow(every: 1mo, fn: count, createEmpty: false) |> set(key: \"_field\", value: \"volume\")\n\nopen = close \n  |> timeShift(duration: 1mo)\n  |> set(key: \"_field\", value: \"open\")\n\nunion(tables: [open, high, low, close, volume])\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
